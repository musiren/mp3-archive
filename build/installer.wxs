<?xml version="1.0" encoding="UTF-8"?>
<!--
  build/installer.wxs
  WiX Toolset v3 installer definition for mp3-archive (onedir build).

  Prerequisites (Windows only):
    1. Build the onedir bundle first:
         pyinstaller build/windows.spec
    2. Install WiX Toolset v3:
         https://github.com/wixtoolset/wix3/releases
    3. Build the MSI via the helper script (run from project root):
         powershell -ExecutionPolicy Bypass -File build\build_msi.ps1

  The build script runs heat.exe to harvest dist\mp3-archive\ into
  build\files.wxs (AppFiles component group), then compiles and links
  both this file and files.wxs into the final MSI.

  Output:
    dist\mp3-archive.msi

  Notes:
    - UpgradeCode must NEVER change across versions (identifies this product family).
    - Product Id="*" generates a new GUID per build, enabling MajorUpgrade.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!--
    Version is passed in by build_msi.ps1 via: candle -dVersion=YYYY.M.D.0
    Converted from NEWS vYYYYMMDD format, e.g. v20260407 -> 2026.4.7.0
  -->
  <Product Id="*"
           Name="mp3-archive"
           Language="1042"
           Version="$(var.Version)"
           Manufacturer="musiren"
           UpgradeCode="{C8CCDD28-5FA2-443B-9744-2CE67FEAA1A5}">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="MP3 Archive Manager"
             Comments="Audio file metadata manager - scan, tag, and play your music library." />

    <!-- Prevent downgrades; silently replace older versions -->
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Embed the cab file inside the MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- App icon shown in Add/Remove Programs -->
    <Icon Id="AppIcon" SourceFile="..\assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK"    Value="https://github.com/musiren/mp3-archive" />

    <!-- ================================================================== -->
    <!-- Directory layout                                                   -->
    <!-- ================================================================== -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- C:\Program Files\mp3-archive\ (all files harvested by heat) -->
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="mp3-archive" />
      </Directory>

      <!-- Start Menu: Programs\mp3-archive\ -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppStartMenuFolder" Name="mp3-archive">
          <Component Id="StartMenuShortcuts"
                     Guid="{212C5660-B289-461C-AADC-BD869101C064}">

            <Shortcut Id="StartMenuShortcut"
                      Name="mp3-archive"
                      Target="[INSTALLDIR]mp3-archive.exe"
                      WorkingDirectory="INSTALLDIR"
                      Icon="AppIcon" />

            <Shortcut Id="UninstallShortcut"
                      Name="Uninstall mp3-archive"
                      Target="[SystemFolder]msiexec.exe"
                      Arguments="/x [ProductCode]" />

            <!-- Remove the Start Menu folder on uninstall -->
            <RemoveFolder Id="RemoveAppStartMenuFolder"
                          On="uninstall" />

            <!-- Registry key required as KeyPath for this component -->
            <RegistryValue Root="HKCU"
                           Key="Software\musiren\mp3-archive"
                           Name="StartMenuInstalled"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut"
                   Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">
          <Shortcut Id="DesktopShortcut"
                    Name="mp3-archive"
                    Target="[INSTALLDIR]mp3-archive.exe"
                    WorkingDirectory="INSTALLDIR"
                    Icon="AppIcon" />
          <RegistryValue Root="HKCU"
                         Key="Software\musiren\mp3-archive"
                         Name="DesktopInstalled"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>

    </Directory>

    <!-- ================================================================== -->
    <!-- Features                                                           -->
    <!-- ================================================================== -->
    <Feature Id="ProductFeature" Title="mp3-archive" Level="1">
      <!-- All app files harvested from dist\mp3-archive\ by heat.exe -->
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- ================================================================== -->
    <!-- Installer UI (directory selection + progress)                     -->
    <!-- ================================================================== -->
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <!-- Skip the license agreement page (remove this line to re-enable) -->
    <WixVariable Id="WixUILicenseRtf" Value="..\LICENSE.rtf" />

  </Product>
</Wix>
